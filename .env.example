# .env.example - Template for environment variables
# Copy this file to .env and fill in your actual API keys

# Choose which API to use by default (options: thenewsapi, newsdata, worldnewsapi, newsapiorg)
VITE_NEWS_PROVIDER=thenewsapi

# API Keys - Get your keys from:
# TheNewsAPI: https://www.thenewsapi.com/
# NewsData.io: https://newsdata.io/
# WorldNewsAPI: https://worldnewsapi.com/
# NewsAPI.org: https://newsapi.org/

VITE_THENEWSAPI_KEY=your_api_key_here
VITE_NEWSDATA_KEY=your_api_key_here
VITE_WORLDNEWSAPI_KEY=your_api_key_here
VITE_NEWSAPIORG_KEY=your_api_key_here

# Default settings
VITE_DEFAULT_COUNTRY=in
VITE_DEFAULT_LANGUAGE=en
